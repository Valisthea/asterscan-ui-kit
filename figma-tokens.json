{
  "$themes": [
    {
      "id": "asterscan-default",
      "name": "AsterScan",
      "selectedTokenSets": {
        "global": "enabled"
      }
    }
  ],
  "$metadata": {
    "tokenSetOrder": ["global"]
  },
  "global": {
    "color": {
      "primary": {
        "value": "#F4D5B1",
        "type": "color",
        "description": "Primary accent — CTAs, brand highlights, links"
      },
      "primary-hover": {
        "value": "#FFD29F",
        "type": "color",
        "description": "Primary hover state — slightly warmer"
      },
      "primary-light": {
        "value": "#FFE5C5",
        "type": "color",
        "description": "Primary tint — soft surfaces, glows"
      },
      "background": {
        "value": "#0E0E0F",
        "type": "color",
        "description": "Body background — true near-black"
      },
      "surface": {
        "value": "#161618",
        "type": "color",
        "description": "Default surface — cards, sections"
      },
      "surface-raised": {
        "value": "#1C1C1F",
        "type": "color",
        "description": "Raised surface — elevated cards, modals"
      },
      "surface-overlay": {
        "value": "#252528",
        "type": "color",
        "description": "Overlay surface — hover rows, dropdowns"
      },
      "border": {
        "value": "#26262A",
        "type": "color",
        "description": "Default border — cards, dividers"
      },
      "border-strong": {
        "value": "#3A3A3F",
        "type": "color",
        "description": "Strong border — focus, emphasis"
      },
      "text-primary": {
        "value": "#F2F0EE",
        "type": "color",
        "description": "Headlines, key numbers"
      },
      "text-secondary": {
        "value": "#B9B5B0",
        "type": "color",
        "description": "Body text"
      },
      "text-muted": {
        "value": "#7A7770",
        "type": "color",
        "description": "Captions, labels"
      },
      "success": {
        "value": "#22C55E",
        "type": "color",
        "description": "Long, gain, positive PnL"
      },
      "danger": {
        "value": "#EF4444",
        "type": "color",
        "description": "Short, loss, liquidation, error"
      },
      "warning": {
        "value": "#F59E0B",
        "type": "color",
        "description": "Cliff, alert, caution"
      },
      "info": {
        "value": "#3B82F6",
        "type": "color",
        "description": "Informational"
      }
    },
    "fontFamilies": {
      "sans": {
        "value": "DM Sans",
        "type": "fontFamilies",
        "description": "UI, body, headlines (substitute for proprietary TT Turns)"
      },
      "mono": {
        "value": "JetBrains Mono",
        "type": "fontFamilies",
        "description": "Numbers, addresses, prices, tabular content"
      }
    },
    "fontWeights": {
      "regular": { "value": "400", "type": "fontWeights" },
      "medium":  { "value": "500", "type": "fontWeights" },
      "semibold":{ "value": "600", "type": "fontWeights" },
      "bold":    { "value": "700", "type": "fontWeights" },
      "black":   { "value": "800", "type": "fontWeights" }
    },
    "fontSize": {
      "display":   { "value": "48px", "type": "fontSizes" },
      "h1":        { "value": "32px", "type": "fontSizes" },
      "h2":        { "value": "24px", "type": "fontSizes" },
      "h3":        { "value": "18px", "type": "fontSizes" },
      "body-lg":   { "value": "16px", "type": "fontSizes" },
      "body":      { "value": "15px", "type": "fontSizes" },
      "body-sm":   { "value": "13px", "type": "fontSizes" },
      "caption":   { "value": "12px", "type": "fontSizes" },
      "overline":  { "value": "11px", "type": "fontSizes" },
      "micro":     { "value": "10px", "type": "fontSizes" }
    },
    "letterSpacing": {
      "tight":    { "value": "-0.02em", "type": "letterSpacing" },
      "wide":     { "value": "0.02em",  "type": "letterSpacing" },
      "overline": { "value": "0.16em",  "type": "letterSpacing" }
    },
    "lineHeights": {
      "display":  { "value": "1.05",  "type": "lineHeights" },
      "heading":  { "value": "1.2",   "type": "lineHeights" },
      "body":     { "value": "1.55",  "type": "lineHeights" },
      "tight":    { "value": "1.3",   "type": "lineHeights" },
      "caption":  { "value": "1.4",   "type": "lineHeights" }
    },
    "borderRadius": {
      "sm": { "value": "4px",  "type": "borderRadius" },
      "md": { "value": "8px",  "type": "borderRadius" },
      "lg": { "value": "12px", "type": "borderRadius" },
      "xl": { "value": "14px", "type": "borderRadius" },
      "2xl":{ "value": "22px", "type": "borderRadius" },
      "full":{"value": "9999px","type": "borderRadius" }
    },
    "spacing": {
      "0":  { "value": "0",    "type": "spacing" },
      "1":  { "value": "4px",  "type": "spacing" },
      "2":  { "value": "8px",  "type": "spacing" },
      "3":  { "value": "12px", "type": "spacing" },
      "4":  { "value": "16px", "type": "spacing" },
      "5":  { "value": "20px", "type": "spacing" },
      "6":  { "value": "24px", "type": "spacing" },
      "8":  { "value": "32px", "type": "spacing" },
      "10": { "value": "40px", "type": "spacing" },
      "12": { "value": "48px", "type": "spacing" }
    }
  }
}
